# ── Hugging Face credentials ──────────────────────────────────────────────────
# Required only for gated models (Llama 3.2, Gemma 3).
# Get a token at https://huggingface.co/settings/tokens
# Accept model-specific licences at the model card before use.
# Leave blank to fall back to the ungated Danube3-500M or a GGUF profile.
HF_TOKEN=hf_your_token_here

# ── Hugging Face cache directory ──────────────────────────────────────────────
# All three variables point to the same directory; set to a path with enough
# space for model weights (~1–3 GB per model in float16).
#
# Linux / macOS example:
# HF_HOME=/home/youruser/.cache/huggingface
#
# Windows example:
# HF_HOME=C:\Users\youruser\.cache\huggingface
HF_HOME=/home/youruser/.cache/huggingface
HUGGINGFACE_HUB_CACHE=/home/youruser/.cache/huggingface
TRANSFORMERS_CACHE=/home/youruser/.cache/huggingface

# ── Optional HF hub tweaks ────────────────────────────────────────────────────
# Suppress the symlink warning on Windows filesystems (set to 1 on Windows)
HF_HUB_DISABLE_SYMLINKS_WARNING=0

# Enable faster downloads via hf_transfer (pip install hf_transfer)
HF_HUB_ENABLE_HF_TRANSFER=0

# ── Model profile override ────────────────────────────────────────────────────
# Overrides active_profile in model_config.yaml without editing the file.
# Valid values: llama32_1b_instruct | gemma3_1b | danube3_500m | llama32_1b_q4km
# MODEL_PROFILE=danube3_500m

# ── LanceDB store path ────────────────────────────────────────────────────────
# Leave unset to use the default ./lancedb_store directory next to the scripts.
# LANCEDB_STORE_PATH=./lancedb_store
