# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── HuggingFace model cache (large; paths vary by OS) ─────────────────────────
# Windows-style literal (double-backslash required for gitignore escaping)
C:\\AIgnatov\\hf_cache/
# Generic glob fallbacks
*hf_cache*/
*hf_cache/
# Standard HF_HOME locations
~/.cache/huggingface/
.cache/huggingface/

# ── Large model weight files ───────────────────────────────────────────────────
# GGUF quantised binaries
*.gguf
# Raw weight shards (transformers / pytorch)
*.bin
*.safetensors
*.pt
*.pth
# llama-cpp-python compiled objects
*.so
*.dll

# ── Ephemeral run artefacts ────────────────────────────────────────────────────
results_*.json
log_*.txt
cpu_monitor.log
/tmp/

*.txn
*.lance
*.manifest
/lancedb_store/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── YAML local overrides (keep model_config.yaml; ignore personal overrides) ──
model_config.local.yaml

# ── LanceDB store is intentionally committed (small KB, version-controlled) ───

